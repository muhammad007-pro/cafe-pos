# Database
DATABASE_URL=sqlite:///./pos.db
# PostgreSQL uchun:
# DATABASE_URL=postgresql://user:password@localhost/restaurant_pos
# MySQL uchun:
# DATABASE_URL=mysql+pymysql://user:password@localhost/restaurant_pos

# Security
SECRET_KEY=your-super-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:5500","http://127.0.0.1:5500"]

# App
DEBUG=True
ENVIRONMENT=development
TIMEZONE=Asia/Tashkent

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=static/uploads

# Printer
PRINTER_ENABLED=False
PRINTER_PORT=COM1
PRINTER_BAUD_RATE=9600

# Payment - Click
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Payment - Payme
PAYME_MERCHANT_ID=
PAYME_KEY=
PAYME_TEST_MODE=True

# SMS Notification (ixtiyoriy)
SMS_API_KEY=
SMS_SENDER_ID=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@restaurant.uz

# Backup
BACKUP_ENABLED=True
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP_DAYS=30