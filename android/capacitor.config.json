{
  "appId": "uz.premiumpos.pro",
  "appName": "PremiumPOS Pro",
  "webDir": "../frontend",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*"],
    "hostname": "localhost"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#0a0a0f",
    "icon": "resources/icon.png",
    "splash": "resources/splash.png"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0f",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "spinnerColor": "#d4af37",
      "spinnerStyle": "large"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_premiumpos",
      "iconColor": "#d4af37",
      "sound": "notification.wav"
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorCookies": {
      "enabled": true
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0a0f",
      "overlaysWebView": false
    },
    "App": {
      "appUrlOpen": {
        "android": {
          "allowNavigation": ["*"]
        }
      }
    },
    "Haptics": {
      "enabled": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "BluetoothLe": {
      "enabled": true
    },
    "Network": {
      "enabled": true
    }
  }
}